{
    "workbench.editor.empty.hint": "hidden",
    "security.workspace.trust.untrustedFiles": "open",
    "editor.cursorStyle": "block",
    "editor.cursorBlinking": "solid",
    "vim.enableNeovim": false,
    "vim.replaceWithRegister": false,
    "vim.easymotion": true,
    "vim.statusBarColorControl": false,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "j"
            ],
            "after": [
                "<Esc>"
            ]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "d"
            ],
            "after": [
                "d",
                "d"
            ]
        },
        {
            "before": [
                "<Leader>",
                "/"
            ],
            "commands": [
                ":noh"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "lineBreakInsert"
            ],
            "silent": true
        },
        {
            "before": [
                "<C-n>"
            ],
            "commands": [
                "workbench.action.focusNextPart"
            ]
        },
        {
            "before": [
                "<C-p>"
            ],
            "commands": [
                "workbench.action.focusPreviousPart"
            ]
        },
        {
            "before": [
                "<leader>",
                "p"
            ],
            "after": [
                "<Esc>",
                "G",
                "o",
                "<Esc>",
                "y",
                "y",
                "2",
                "0",
                "p",
                "5",
                "k"
            ]
        }
    ],
    "vim.normalModeKeyBindings": [
        {
            "before": [
                "|"
            ],
            "after": [
                "<C-w>",
                "v"
            ]
        },
        {
            "before": [
                "leader",
                "e"
            ],
            "commands": [
                ":wqall!"
            ]
        },
        {
            "before": [
                "g",
                "r"
            ],
            "after": [
                "g",
                "T"
            ]
        },
        {
            "before": [
                "leader",
                "q"
            ],
            "commands": [
                ":q!"
            ]
        },
        {
            "before": [
                "<C-f>"
            ],
            "commands": [
                "actions.find"
            ]
        },
        {
            "before": [
                "leader",
                "s"
            ],
            "commands": [
                "workbench.action.files.save"
            ]
        },
        {
            "before": [
                "leader",
                "w"
            ],
            "commands": [
                ":wq!"
            ]
        },
        {
            "before": [
                "g",
                "S"
            ],
            "commands": [
                "references-view.find"
            ]
        },
        {
            "before": [
                "g",
                "R"
            ],
            "commands": [
                "editor.action.referenceSearch.trigger"
            ]
        },
        {
            "before": [
                "g",
                "s"
            ],
            "commands": [
                "editor.action.revealDefinitionAside"
            ]
        },
        {
            "before": [
                "g",
                "D"
            ],
            "commands": [
                "editor.action.peekDefinition"
            ]
        },
        {
            "before": [
                "g",
                "x"
            ],
            "commands": [
                "editor.action.openLink"
            ]
        },
        {
            "before": [
                "<C-n>"
            ],
            "commands": [
                ":nohl"
            ]
        }
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                ">"
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },
        {
            "before": [
                "<"
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        },
        {
            "before": [
                "$"
            ],
            "after": [
                "g",
                "_"
            ]
        }
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": [
                "p"
            ],
            "after": [
                "p",
                "g",
                "v",
                "y"
            ]
        }
    ],
    "vim.handleKeys": {
        "<C-j>": false,
        "<C-k>": false,
        "<C-n>": false,
        "<C-f>": false,
        "<C-b>": false,
        "<C-o>": false,
        "<C-h>": false,
        "<C-]>": false,
        "<C-p>": false,
        "<C-e>": false,
        "<C-d>": true,
        "<C-u>": true
    },
    "editor.minimap.enabled": false,
    "workbench.colorTheme": "Solarized Custom Dark",
    "markdownlint.config": {
        "MD041": false,
        "MD013": false,
        "MD012": false,
        "MD046": false,
        "MD049": false,
        "MD059": false,
        "MD026": false,
        "no-hard-tabs": false,
        "MD007": {
            "indent": 2
        }
    },
    "remote.autoForwardPortsSource": "hybrid",
    "redhat.telemetry.enabled": true,
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "zenMode.showTabs": "none",
    "zenMode.hideStatusBar": true,
    "zenMode.hideActivityBar": true,
    "zenMode.centerLayout": false,
    "workbench.editor.enablePreviewFromCodeNavigation": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "editor.fontSize": 15,
    "editor.fontFamily": "'JetBrainsMono NF', 'FiraCode NF', 'Cascadia Code NF'",
    "editor.fontLigatures": true,
    "terminal.integrated.fontSize": 16,
    "window.zoomLevel": 1,
    "todo-tree.general.statusBar": "current file",
    "todo-tree.general.tags": [
        "TODO",
        "FIXME",
        "NICETOHAVE",
        "DOING"
    ],
    "todo-tree.highlights.customHighlight": {
        "TODO": {
            "foreground": "#64dd17",
            "background": "#008800"
        },
        "FIXME": {
            "foreground": "#f44336",
            "background": "#592c2c"
        },
        "NICETOHAVE": {
            "foreground": "#efbcd4",
            "background": "#592c2c"
        },
        "DOING": {
            "foreground": "#c09eb6",
            "background": "#428cc9"
        }
    },
    "dimmer.enabled": {
        "default": true,
        "description": "When set to true, the extension will dim non-selected text."
    },
    "dimmer.toggleDimmerCommandScope": {
        "defualt": "user",
        "description": "Decides whether the `ToggleDimmer` command will affect the user (global) or workspace (local) settings."
    },
    "dimmer.opacity": {
        "default": 50,
        "description": "An integer between 0 and 100 used for the opacity percentage for the dimmed (non-selected) text."
    },
    "dimmer.delay": {
        "default": 0,
        "description": "Delay in milliseconds for dimming the non-selected text to reduce number of API calls in the event of rapid selection changes. Defaults to 0, but set higher if it feels like it is causing problems."
    },
    "aws.cloudformation.telemetry.enabled": false,
    "sonarlint.automaticAnalysis": false,
    "files.exclude": {
        "**/*.code-workspace": true
    },
    "editor.lineNumbers": "on",
    "workbench.sideBar.location": "right",
    "workbench.activityBar.location": "top",
    "workbench.auxiliaryActivityBar.location": "default",
    "aws.telemetry": false,
    "window.menuBarVisibility": "compact",
    "window.customTitleBarVisibility": "windowed"
}